def flush_realtime_rep_buffer(
    realtime_rep_buffer: list[dict],
    db_path: str = DB_PATH,
    allow_db_insert: bool = False,
) -> Optional[str]:
    if not realtime_rep_buffer:
        return None

    saved_json_path: Optional[str] = None
    try:
        results_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), "results")
        os.makedirs(results_dir, exist_ok=True)
        ts = time.strftime("%Y%m%d_%H%M%S")
        saved_json_path = os.path.join(results_dir, f"realtime_rep_buffer_{ts}.json")
        with open(saved_json_path, "w", encoding="utf-8") as f:
            json.dump(realtime_rep_buffer, f, ensure_ascii=False, indent=2)
        logger.info("[REALTIME_REP_BUFFER_SAVED] path=%s count=%d", saved_json_path, len(realtime_rep_buffer))
    except Exception as e:
        logger.exception("[REALTIME_REP_BUFFER_SAVE_ERROR] err=%s", e)

    if not allow_db_insert:
        return saved_json_path

    for item in realtime_rep_buffer:
        try:
            mcv = item.get("mcv")
            rom_m = item.get("rom_m")
            if mcv is None or rom_m is None:
                continue
            _insert_rep_async(
                db_path,
                int(item.get("rep") or 0),
                float(mcv),
                float(rom_m),
                item.get("left_knee"),
                item.get("right_knee"),
                item.get("trunk"),
                None,
                item.get("depth_offset_cm"),
                float(item.get("load_kg") or 0.0),
                item.get("velocity_loss"),
                str(item.get("user_name") or "Guest"),
                item.get("rom_completion_pct"),
                item.get("set_number"),
                item.get("session_id"),
                item.get("user_height_cm"),
                item.get("pose_issues"),
                calib_method=item.get("calib_method"),
                calib_is_fallback=item.get("calib_is_fallback"),
                timing_source=item.get("timing_source"),
            )
            logger.info("[REALTIME_REP_FLUSH_OK] rep=%s", item.get("rep"))
        except Exception as e:
            logger.exception("[REALTIME_REP_FLUSH_ERROR] rep=%s err=%s", item.get("rep"), e)

    return saved_json_path


