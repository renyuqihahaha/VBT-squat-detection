def _clamp_m_per_px(value: Optional[float]) -> Optional[float]:
    if value is None:
        return None
    try:
        v = float(value)
    except (TypeError, ValueError):
        return None
    if MIN_STABLE_M_PER_PX <= v <= MAX_STABLE_M_PER_PX:
        return v
    return None


def safe_compute_depth(
    top_y: Optional[float],
    bottom_y: Optional[float],
    m_per_px: Optional[float],
    last_valid_depth_m: Optional[float] = None,
) -> tuple[Optional[float], Optional[str], Optional[float]]:
    if top_y is None or bottom_y is None or m_per_px is None:
        return last_valid_depth_m, "missing_input", None

    try:
        pixel_delta = abs(float(bottom_y) - float(top_y))
    except (TypeError, ValueError):
        return last_valid_depth_m, "bad_input", None

    if pixel_delta < 20 or pixel_delta > 400:
        return last_valid_depth_m, f"bad_pixel_delta={pixel_delta:.1f}", pixel_delta

    raw_depth = pixel_delta * float(m_per_px)
    if raw_depth < 0.25 or raw_depth > 0.80:
        return last_valid_depth_m, f"bad_depth={raw_depth:.3f}", pixel_delta

    return raw_depth, None, pixel_delta


