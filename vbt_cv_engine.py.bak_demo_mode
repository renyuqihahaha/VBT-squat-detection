class VideoWriterWorker:
    """Async writer to prevent VideoWriter.write() from blocking CV loop."""

    def __init__(self, writer: cv2.VideoWriter, maxsize: int = VIDEO_WRITE_QUEUE_SIZE) -> None:
        self._writer = writer
        self._queue: queue.Queue[Optional[np.ndarray]] = queue.Queue(maxsize=maxsize)
        self._stop_event = threading.Event()
        self._thread = threading.Thread(target=self._run, daemon=True, name="vbt-video-writer")
        self.dropped_frames = 0
        self.written_frames = 0
        self.last_drop_log_ts = 0.0
        self._thread.start()

    def submit(self, frame: np.ndarray) -> bool:
        if self._stop_event.is_set():
            return False
        try:
            # Copy here so producer can safely keep mutating original frame.
            self._queue.put_nowait(frame.copy())
            return True
        except queue.Full:
            self.dropped_frames += 1
            return False

    def qsize(self) -> int:
        try:
            return int(self._queue.qsize())
        except Exception:
            return -1

    def _run(self) -> None:
        while not self._stop_event.is_set() or not self._queue.empty():
            try:
                item = self._queue.get(timeout=0.2)
            except queue.Empty:
                continue
            if item is None:
                self._queue.task_done()
                break
            try:
                self._writer.write(item)
                self.written_frames += 1
            except Exception as e:
                logger.warning("后台视频写入失败: %s", e)
            finally:
                self._queue.task_done()

    def stop(self) -> None:
        self._stop_event.set()
        # Drop queued frames on shutdown so writer thread can exit quickly.
        while True:
            try:
                item = self._queue.get_nowait()
            except queue.Empty:
                break
            if item is not None:
                self.dropped_frames += 1
            self._queue.task_done()
        try:
            self._queue.put_nowait(None)
        except queue.Full:
            pass
        self._thread.join(timeout=3.0)


